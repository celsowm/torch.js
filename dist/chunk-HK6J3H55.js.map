export default "@group(0) @binding(0) var<storage, read> input: array<f32>;\n@group(0) @binding(1) var<storage, read_write> output: array<f32>;\n\nstruct Params {\n  rows: u32,\n  cols: u32,\n  diagonal: i32,\n  _pad: u32,\n}\n@group(0) @binding(2) var<uniform> params: Params;\n\n@compute @workgroup_size(256)\nfn main(@builtin(global_invocation_id) gid: vec3<u32>) {\n  let idx = gid.x;\n  let total = params.rows * params.cols;\n  if (idx >= total) { return; }\n\n  let row = idx / params.cols;\n  let col = idx % params.cols;\n\n  // Keep element if col <= row + diagonal\n  if (i32(col) <= i32(row) + params.diagonal) {\n    output[idx] = input[idx];\n  } else {\n    output[idx] = 0.0;\n  }\n}\n";